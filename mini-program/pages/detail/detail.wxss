.cover-wrap {
  padding: 20rpx 0 40rpx;
  display: flex;
  justify-content: center;
}
.cover-img {
  width: 380rpx;
  height: 540rpx;
  border-radius: 12rpx;
  background: #F1F2F4;
  box-shadow:
    -2rpx 0 0 rgba(0,0,0,0.06),
    24rpx 24rpx 60rpx rgba(15,27,59,0.18);
}
.cover {
  width: 380rpx;
  height: 540rpx;
  border-radius: 12rpx;
  box-shadow:
    -2rpx 0 0 rgba(0,0,0,0.06),
    24rpx 24rpx 60rpx rgba(15,27,59,0.18);
  padding: 50rpx 40rpx;
  box-sizing: border-box;
  color: #FFFFFF;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  position: relative;
}
.cover::before {
  content: '';
  position: absolute;
  left: 12rpx;
  top: 0; bottom: 0;
  width: 1rpx;
  background: rgba(255,255,255,0.18);
}
.cover-en {
  font-size: 22rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  opacity: 0.7;
}
.cover-title {
  font-size: 56rpx;
  font-weight: 600;
  line-height: 1.3;
  letter-spacing: 2rpx;
}
.cover-foot {
  font-size: 20rpx;
  letter-spacing: 2rpx;
  opacity: 0.6;
}

.info {
  padding: 20rpx 0 40rpx;
}
.info-title {
  font-size: 52rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}
.info-en {
  font-size: 24rpx;
  letter-spacing: 1rpx;
  margin-bottom: 36rpx;
}

.info-meta {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-top: 1rpx solid #F1F2F4;
  border-bottom: 1rpx solid #F1F2F4;
  margin-bottom: 36rpx;
}
.meta-cell {
  flex: 1;
  text-align: center;
}
.meta-num {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}
.meta-label {
  font-size: 20rpx;
  letter-spacing: 2rpx;
}
.meta-divider {
  width: 1rpx;
  height: 56rpx;
  background: #F1F2F4;
}

.info-desc {
  font-size: 28rpx;
  line-height: 1.8;
  color: #1F2937;
  margin-bottom: 16rpx;
}
.info-pitch {
  font-size: 22rpx;
  letter-spacing: 1rpx;
  font-style: italic;
}

.cta-stack {
  margin-top: 40rpx;
  margin-bottom: 30rpx;
}
.cta-stack button { margin-bottom: 20rpx; }
.cta-or {
  text-align: center;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  margin: 16rpx 0 24rpx;
}
.cta-foot {
  text-align: center;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.error-box {
  background: #FEF2F2;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}
.error-title {
  color: #B91C1C;
  font-weight: 600;
  margin-bottom: 8rpx;
}
.error-msg {
  font-size: 22rpx;
  color: #7F1D1D;
}

.tx-box {
  background: #F0FDF4;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}
.tx-title {
  color: #047857;
  font-weight: 600;
  margin-bottom: 8rpx;
}
.tx-hash {
  font-size: 20rpx;
}

.footer-note {
  text-align: center;
  font-size: 20rpx;
  letter-spacing: 1rpx;
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}
