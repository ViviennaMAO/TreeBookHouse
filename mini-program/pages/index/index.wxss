.hero {
  padding: 40rpx 0 60rpx;
}

.brand-mark {
  display: flex;
  align-items: flex-end;
  gap: 6rpx;
  height: 80rpx;
  margin-bottom: 36rpx;
}
.mark-spine {
  width: 12rpx;
  border-radius: 4rpx;
}
.brand-mark .mark-spine:nth-child(1) { height: 78rpx; }
.brand-mark .mark-spine:nth-child(2) { height: 60rpx; }
.brand-mark .mark-spine:nth-child(3) { height: 72rpx; }
.brand-mark .mark-spine:nth-child(4) { height: 54rpx; }
.brand-mark .mark-spine:nth-child(5) { height: 66rpx; }

.hero-title {
  font-size: 72rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  margin-bottom: 14rpx;
  color: #0F1B3B;
}
.hero-sub {
  font-size: 26rpx;
  letter-spacing: 2rpx;
}

/* 钱包未授权横幅 — 软登录失败时显示,点击重新唤起 connect */
.auth-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FEF3C7;
  border: 1rpx solid #FCD34D;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 32rpx;
}
.auth-text { flex: 1; }
.auth-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #92400E;
  margin-bottom: 4rpx;
}
.auth-desc {
  font-size: 22rpx;
  letter-spacing: 0.5rpx;
}
.auth-arrow {
  font-size: 32rpx;
  color: #92400E;
  margin-left: 20rpx;
}

/* Bundle CTA */
.bundle-card {
  background: #0F1B3B;
  color: #FFFFFF;
  border-radius: 28rpx;
  padding: 36rpx 36rpx 32rpx;
  margin-bottom: 60rpx;
  position: relative;
  overflow: hidden;
}
.bundle-card::after {
  content: '';
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 50%;
}
.bundle-row-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.bundle-tag {
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: rgba(255,255,255,0.7);
  font-weight: 500;
}
.bundle-arrow {
  font-size: 40rpx;
  color: rgba(255,255,255,0.7);
  line-height: 1;
}
.bundle-title {
  font-size: 44rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #FFFFFF;
}
.bundle-meta {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}
.bundle-price {
  font-size: 64rpx;
  font-weight: 600;
  font-family: "Songti SC", Georgia, serif;
  letter-spacing: 1rpx;
}
.bundle-currency {
  font-size: 28rpx;
  margin-left: 8rpx;
  color: rgba(255,255,255,0.85);
}
.bundle-strike {
  font-size: 22rpx;
  margin-left: 20rpx;
  color: rgba(255,255,255,0.45);
  text-decoration: line-through;
}
.bundle-foot {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  letter-spacing: 1rpx;
}

/* Section head */
.section-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 40rpx;
  font-weight: 600;
}
.section-meta {
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

/* Shelf */
.shelf {
  margin-bottom: 60rpx;
}
.book-row {
  display: flex;
  background: #FFFFFF;
  padding: 28rpx 4rpx 28rpx 0;
  border-bottom: 1rpx solid #F1F2F4;
  align-items: stretch;
}
.book-row:last-child { border-bottom: none; }

.book-spine {
  width: 8rpx;
  border-radius: 4rpx;
  margin-right: 28rpx;
  min-height: 120rpx;
  flex-shrink: 0;
}

.book-thumb {
  width: 110rpx;
  height: 156rpx;
  border-radius: 6rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
  background: #F1F2F4;
  box-shadow:
    -1rpx 0 0 rgba(0,0,0,0.06),
    6rpx 6rpx 16rpx rgba(15,27,59,0.08);
}

.book-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.book-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}
.book-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #0F1B3B;
}
.book-chevron {
  font-size: 36rpx;
  line-height: 1;
}
.book-en {
  font-size: 22rpx;
  letter-spacing: 1rpx;
  margin-bottom: 16rpx;
}
.book-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
}
.dot { color: #D1D5DB; }

.footer-note {
  text-align: center;
  font-size: 20rpx;
  letter-spacing: 1rpx;
  margin-top: 80rpx;
  padding-bottom: 40rpx;
}
